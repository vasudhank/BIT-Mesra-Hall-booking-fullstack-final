# ----------------------------
# Support workflow runtime
# ----------------------------
# AGENT_GRAPH (legacy fallback) or LANGGRAPH_COMPAT (real @langchain/langgraph runtime)
SUPPORT_GRAPH_RUNTIME=LANGGRAPH_COMPAT
LANGGRAPH_REAL_ENABLED=true

# Persistent agent memory
AI_MEMORY_EXTRACTION_ENABLED=true
AI_MEMORY_VECTOR_ENABLED=true
AI_MEMORY_CONTEXT_CHARS=4200
AI_MEMORY_RECENT_MESSAGES=10
AI_MEMORY_RELEVANT_LIMIT=8

# Vector store deployment
# local -> Mongo-backed vectors
# pinecone -> managed Pinecone index
# weaviate -> remote or self-hosted Weaviate cluster
VECTOR_DB_PROVIDER=local
VECTOR_DEFAULT_NAMESPACE=support_knowledge
VECTOR_SYNC_ENABLED=true
VECTOR_SYNC_INTERVAL_MS=1800000
VECTOR_PROVIDER_REQUIRED=false
VECTOR_PROBE_TIMEOUT_MS=5000
PINECONE_API_KEY=
PINECONE_INDEX_URL=
WEAVIATE_URL=
WEAVIATE_API_KEY=
WEAVIATE_CLASS=SupportChunk

# OpenAI-compatible API key setup (supports Gemini OpenAI endpoint too)
# Use OPENAI_API_KEYS for automatic key failover/rotation on rate limits.
# Keep OPENAI_API_KEY for backward compatibility or single-key usage.
OPENAI_API_KEYS=
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ----------------------------
# Production observability
# ----------------------------
# Prometheus/Grafana scrape: GET /api/ops/metrics?format=prom
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001

# Sentry error and performance monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_PROJECT_URL=

# Datadog APM. For container/local monitoring, run:
# docker compose --profile monitoring up
DATADOG_ENABLED=false
DD_TRACE_ENABLED=false
DD_AGENT_HOST=datadog-agent
DD_SERVICE=bit-booking-backend
DD_ENV=production
DD_RUNTIME_METRICS_ENABLED=true
DD_LOGS_INJECTION=true
DATADOG_DASHBOARD_URL=

# ----------------------------
# WhatsApp Cloud API (Meta)
# Free test mode works with a test phone number in Meta dashboard.
# ----------------------------
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_BASE=https://graph.facebook.com
WHATSAPP_API_VERSION=v20.0
WHATSAPP_AUTO_REPLY_ENABLED=true

# ----------------------------
# Slack
# Incoming webhook alone is enough for notifications.
# Bot token is needed for channel/thread replies.
# ----------------------------
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_INCOMING_WEBHOOK_URL=
SLACK_AUTO_REPLY_ENABLED=true

# ----------------------------
# CRM (HubSpot Free)
# ----------------------------
CRM_PROVIDER=hubspot
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_BASE_URL=https://api.hubapi.com

# Auto sync generated support thread summaries into CRM notes
CRM_AUTO_SYNC_SUPPORT_THREADS=false

# ----------------------------
# Mongo / Session resilience
# ----------------------------
MONGO_RETRY_INTERVAL_MS=10000
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_MAX_POOL_SIZE=80
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_IDLE_TIME_MS=30000
MONGO_FAMILY=4
SESSION_STORE_USE_MONGO=true

# ----------------------------
# Request control + server load shedding
# ----------------------------
MAX_ACTIVE_REQUESTS=900
RATE_LIMIT_DEFAULT_WINDOW_MS=60000
RATE_LIMIT_DEFAULT_MAX=240
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=40
RATE_LIMIT_BOOKING_WINDOW_MS=60000
RATE_LIMIT_BOOKING_MAX=80
RATE_LIMIT_AI_WINDOW_MS=60000
RATE_LIMIT_AI_MAX=80
RATE_LIMIT_WRITE_WINDOW_MS=60000
RATE_LIMIT_WRITE_MAX=140

# HTTP socket and graceful shutdown tuning
SERVER_KEEP_ALIVE_TIMEOUT_MS=65000
SERVER_HEADERS_TIMEOUT_MS=66000
SERVER_REQUEST_TIMEOUT_MS=120000
SERVER_MAX_REQUESTS_PER_SOCKET=1000
SHUTDOWN_GRACE_MS=15000

# ----------------------------
# Mail sync
# ----------------------------
# Set false to disable noisy sync retries in local/offline environments.
COMPLAINT_MAIL_SYNC_ENABLED=true
NOTICE_MAIL_SYNC_ENABLED=true

# Optional IMAP host override if your DNS/network cannot resolve imap.gmail.com.
MAIL_IMAP_HOST=imap.gmail.com
COMPLAINT_MAIL_IMAP_HOST=
NOTICE_MAIL_IMAP_HOST=
